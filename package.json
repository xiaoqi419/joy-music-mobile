{
  "name": "joy-music-mobile",
  "version": "1.2.4",
  "description": "A React Native music player for iOS using Expo",
  "private": true,
  "scripts": {
    "start": "EXPO_UNSTABLE_HEADLESS=1 npx expo start",
    "ios": "EXPO_UNSTABLE_HEADLESS=1 expo start --ios",
    "android": "EXPO_UNSTABLE_HEADLESS=1 expo start --android",
    "web": "EXPO_UNSTABLE_HEADLESS=1 expo start --web",
    "tunnel": "EXPO_UNSTABLE_HEADLESS=1 expo start --tunnel",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "test": "jest",
    "release:version": "node scripts/release-tag.mjs"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-native-community/slider": "5.1.2",
    "crypto-js": "^4.2.0",
    "expo": "^55.0.0",
    "expo-audio": "~55.0.8",
    "expo-blur": "~55.0.8",
    "expo-document-picker": "~55.0.8",
    "expo-file-system": "~55.0.10",
    "expo-haptics": "~55.0.8",
    "expo-linear-gradient": "~55.0.8",
    "expo-splash-screen": "~55.0.10",
    "expo-sqlite": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "iconv-lite": "^0.7.2",
    "pako": "^2.1.0",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-worklets": "0.7.2",
    "react-redux": "^9.0.0",
    "redux": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native/eslint-config": "^0.84.1",
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.10",
    "@types/react-test-renderer": "^19.1.0",
    "babel-preset-expo": "~55.0.8",
    "eslint": "^9.39.3",
    "jest": "~29.7.0",
    "prettier": "2.8.8",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=8.5.2"
  },
  "overrides": {
    "eslint-plugin-ft-flow": "^3.0.11",
    "react-native": {
      "glob": "^10.4.5"
    },
    "@react-native/codegen": {
      "glob": "^10.4.5"
    },
    "@jest/reporters": {
      "glob": "^10.4.5"
    },
    "jest-config": {
      "glob": "^10.4.5"
    },
    "jest-runtime": {
      "glob": "^10.4.5"
    },
    "test-exclude": {
      "glob": "^10.4.5"
    }
  }
}
